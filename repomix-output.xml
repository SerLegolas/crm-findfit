import { NextRequest, NextResponse } from "next/server";
import { ImapFlow } from "imapflow";
import { simpleParser } from "mailparser";

export const runtime = "nodejs";

export async function GET(_request: NextRequest) {
  try {
    const host = process.env.IMAP_HOST;
    const port = parseInt(process.env.IMAP_PORT || "993");
    const user = process.env.IMAP_USER;
    const password = process.env.IMAP_PASSWORD;

    if (!host || !user || !password) {
      return NextResponse.json(
        { error: "Credenziali IMAP mancanti. Configura IMAP_HOST, IMAP_USER, IMAP_PASSWORD nelle variabili d'ambiente." },
        { status: 500 }
      );
    }

    const filterFrom = (process.env.ARUBA_FILTER_FROM || "").toLowerCase();

    const client = new ImapFlow({
      host,
      port,
      secure: port === 993,
      auth: { user, pass: password },
      logger: false,
    });

    await client.connect();

    const lock = await client.getMailboxLock("INBOX");
    try {
      const searchResult = await client.search({ unseen: true });

      const uidList = searchResult.length > 0 ? searchResult : [];

      const emails: {
        mittente: string;
        oggetto: string;
        bodyText: string;
        data: string;
      }[] = [];
      let filtrate = 0;

      for (const uid of uidList) {
        // Recupera source grezzo
        const message = await client.fetchOne(uid, { source: true });

        // Parsing completo con mailparser
        let parsed;
        try {
          parsed = await simpleParser(message.source as Buffer);
        } catch {
          continue;
        }

        // Filtra per mittente
        const fromAddress =
          parsed.from && parsed.from.value && parsed.from.value.length > 0
            ? parsed.from.value[0].address?.toLowerCase() || ""
            : "";

        if (filterFrom && fromAddress !== filterFrom) {
          filtrate++;
          continue;
        }

        // Mittente formattato
        const mittente =
          parsed.from && parsed.from.value && parsed.from.value.length > 0
            ? `${parsed.from.value[0].name || ""} <${parsed.from.value[0].address}>`.trim()
            : "Sconosciuto";

        // Oggetto
        const oggetto = parsed.subject || "(nessun oggetto)";

        // Data
        const data = parsed.date
          ? new Date(parsed.date).toLocaleString("it-IT")
          : "";

        // Corpo
        const bodyText = (parsed.text || parsed.html || "(corpo non disponibile)").trim();

        emails.push({ mittente, oggetto, bodyText, data });

        // Segna l'email come letta su Aruba
        await client.messageFlagsAdd(uid, ["\\Seen"]);
      }

      return NextResponse.json({
        emails,
        totali: searchResult.length,
        filtrate,
        sincronizzate: emails.length,
      });
    } finally {
      lock.release();
      await client.logout();
    }
  } catch (error: any) {
    console.error("Errore IMAP sync:", error);
    return NextResponse.json(
      {
        error: `Errore durante la sincronizzazione IMAP: ${error.message || "Errore sconosciuto"}`,
      },
      { status: 500 }
    );
  }
}
